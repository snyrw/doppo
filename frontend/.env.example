# ─── Modal inference backend ─────────────────────────────────────────────────
# URL of the deployed Modal app, e.g. https://yourorg--logitlensviz-api.modal.run
NEXT_PUBLIC_API_URL=

# ─── Stripe billing ───────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── App URL ──────────────────────────────────────────────────────────────────
# http://localhost:3000 for local dev; your production domain when deployed
NEXT_PUBLIC_APP_URL=
BETTER_AUTH_URL=

# ─── Neon Postgres ────────────────────────────────────────────────────────────
# postgresql://... connection string from the Neon dashboard (use the pooled URL)
DATABASE_URL=

# ─── BetterAuth ───────────────────────────────────────────────────────────────
# Random secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
# Used to cache heatmap results so repeated runs skip Modal inference
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ─── OAuth providers ──────────────────────────────────────────────────────────
# At least one provider is required; both are optional
# Google: https://console.developers.google.com → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── HuggingFace ──────────────────────────────────────────────────────────────
# Required only for gated models (e.g. Llama, Gemma)
# https://huggingface.co/settings/tokens
HF_TOKEN=

# ─── Email / Resend (optional) ────────────────────────────────────────────────
# Leave blank in local dev — verification links print to the console instead
# https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=
